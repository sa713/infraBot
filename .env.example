# Telegram bot token from @BotFather
BOT_TOKEN=123456789:REPLACE_ME

# Telegram user IDs allowed to control services (comma-separated)
ALLOWED_USER_IDS=123456789

# Chat IDs to receive alerts (optional, defaults to ALLOWED_USER_IDS)
ALERT_CHAT_IDS=123456789

# Services to monitor and control via systemctl (comma-separated)
MONITORED_SERVICES=bot-alpha.service,bot-beta.service

# VPN service (optional). If set, it is added automatically to MONITORED_SERVICES.
VPN_SERVICE=wg-quick@wg0.service

# Monitoring interval in seconds
CHECK_INTERVAL_SEC=60

# Daily report time (HH:MM, server local time)
DAILY_REPORT_TIME=08:00

# Timeout for each systemctl command
COMMAND_TIMEOUT_SEC=15

# Use sudo systemctl commands (true/false)
USE_SUDO=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
